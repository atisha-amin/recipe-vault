# .streamlit/secrets.toml
# Copy this file to .streamlit/secrets.toml and fill in your Turso credentials.
# This file is listed in .gitignore and must NEVER be committed to git.
#
# How to get these values:
#   1. Create a free account at https://turso.tech
#   2. Run: turso db create recipe-vault
#   3. Run: turso db show recipe-vault   → copy the URL
#   4. Run: turso db tokens create recipe-vault  → copy the token
#
# For Streamlit Community Cloud:
#   Paste these values in App Settings > Secrets (same key names).

TURSO_DATABASE_URL = "libsql://your-database-name.turso.io"
TURSO_AUTH_TOKEN   = "your-auth-token-here"
